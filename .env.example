# Copy to .env.local and adjust. For typical local dev, leave API/socket vars unset.

# --- Backend must be running on port 5000 ---
# From repo root: npm run server
# Or: cd server && npm run dev

# --- Recommended local dev (use Vite proxy on port 3000) ---
# Leave these unset so the app uses /api and same-origin Socket.IO (see vite.config.js).
# VITE_API_URL=
# VITE_SOCKET_URL=

# If you set VITE_API_URL=http://localhost:5000/api you bypass the proxy; the API must still be up or you get ERR_CONNECTION_REFUSED.

# --- Google Sign-In ---
# In Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client ID:
# Add "Authorized JavaScript origins" exactly matching your dev URL, e.g. http://localhost:3000
# VITE_GOOGLE_CLIENT_ID=
